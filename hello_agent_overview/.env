# ============================================================================
# HelloAgents 统一环境变量配置文件
# ============================================================================
# 复制此文件为 .env 并填入你的API密钥
# 系统要求：Python 3.10+ （必需）

# ============================================================================
# 🚀 统一配置格式（推荐）- 框架自动检测provider
# ============================================================================
# 只需配置以下4个通用环境变量，框架会自动识别LLM提供商：

# 模型名称
LLM_MODEL_ID=deepseek-ai/deepseek-v4-flash

# API密钥
LLM_API_KEY=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

# 服务地址
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# 超时时间（可选，默认60秒）
LLM_TIMEOUT=30

# .env file
MODELSCOPE_API_KEY=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

# ============================================================================
# 🛠️ 工具配置（可选）
# ============================================================================

# Tavily搜索（推荐）- 获取API密钥：https://tavily.com/
# TAVILY_API_KEY=tvly-your_tavily_key_here

# SerpApi搜索（备选）- 获取API密钥：https://serpapi.com/
# SERPAPI_API_KEY=your_serpapi_key_here